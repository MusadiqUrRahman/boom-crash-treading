# Deriv API
# API_MODE=legacy (uses @deriv/deriv-api + authorize message) or new (PAT + OTP WebSocket URL)
# DERIV_API_MODE=new is required for PAT-based authentication
# DERIV_API_MODE=new
# API_TOKEN = PAT (Personal Access Token) from app.deriv.com
API_TOKEN=pat_your_token_here
# NEW mode: App ID from developers.deriv.com (alphanumeric, e.g. "33wUlsiHNiB3IYwV65oTW")
# LEGACY mode: numeric App ID from Deriv dashboard (e.g. 1089 for public test)
DERIV_NEW_APP_ID=
# Legacy mode App ID (fallback if DERIV_NEW_APP_ID is not set)
APP_ID=1089
# New mode: specific account ID (auto-detected if empty)
DERIV_ACCOUNT_ID=
# New mode: account type to create if no accounts exist (demo or real)
DERIV_ACCOUNT_TYPE=demo
# Legacy endpoint only (new API URL is hardcoded)
DERIV_ENDPOINT=ws.binaryws.com/

# Symbol & Direction
SYMBOL=BOOM1000

# Contract Type
CONTRACT_TYPE=MULTDOWN

# Bot Mode
DRY_RUN=false
DEBUG_SCORES=false
LOG_LEVEL=INFO

# Strategy Parameters (override best-params.json defaults)
PAYOUT_RATE=0.85
STAKE=1.00
DURATION_TICKS=10
MULTIPLIER=1000
STOP_LOSS=0.10
TAKE_PROFIT=0.10
MAX_ML_DURATION_TICKS=200
MIN_TICKS_BEFORE_TRADE=30
COOLDOWN_TICKS=5
SPIKE_THRESHOLD=2.3
SCORE_THRESHOLD=2

# Indicator Parameters
RSI_PERIOD=14
RSI_OVERSOLD=35
RSI_OVERBOUGHT=65
BB_PERIOD=20
BB_STDDEV=2
EMA_SHORT_PERIOD=5
EMA_LONG_PERIOD=20
ROC_PERIOD=5

# Risk Limits
MAX_CONSECUTIVE_LOSSES=8
MAX_DAILY_LOSS=200
MAX_DAILY_TRADES=500
MAX_POSITION_SIZE=2.00
MAX_DAILY_DRAWDOWN=0.10

# Stake Management
STAKE_MODE=fixed
BASE_STAKE=0.50
MIN_STAKE=0.35
MAX_STAKE=2.00
RISK_PERCENT=0.005
USE_MARTINGALE=false

# Connection
RECONNECT_BASE_DELAY=1000
RECONNECT_MAX_DELAY=30000
MAX_RECONNECT_ATTEMPTS=10
PING_INTERVAL=30000

# Data
DB_PATH=./data/boom_crash_ticks.db
LIVE_TRADES_DB_PATH=./data/live_trades.db
STORE_TICKS=true

# Production (Phase 7)
HEALTH_PORT=3456
LOG_DIR=./logs
REPORT_DIR=./reports/daily
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
