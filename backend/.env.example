# Deriv API
API_TOKEN=
APP_ID=1089
DERIV_ENDPOINT=ws.derivws.com

# Symbol & Direction
SYMBOL=CRASH1000
# Direction auto-detected from symbol (CRASH=CALL, BOOM=PUT)

# Bot Mode
DRY_RUN=true
DEBUG_SCORES=false
LOG_LEVEL=INFO

# Strategy Parameters (override best-params.json defaults)
PAYOUT_RATE=0.85
STAKE=0.50
DURATION_TICKS=10
COOLDOWN_TICKS=5
SCORE_THRESHOLD=5
MIN_SCORE_SPREAD=2

# Indicator Parameters
RSI_PERIOD=14
RSI_OVERSOLD=35
RSI_OVERBOUGHT=65
BB_PERIOD=20
BB_STDDEV=2
EMA_SHORT_PERIOD=5
EMA_LONG_PERIOD=20
ROC_PERIOD=5

# Risk Limits
MAX_CONSECUTIVE_LOSSES=5
MAX_DAILY_LOSS=10
MAX_DAILY_TRADES=100
MAX_POSITION_SIZE=2.00
MAX_DAILY_DRAWDOWN=0.10
STARTING_BALANCE=100

# Stake Management
STAKE_MODE=fixed
BASE_STAKE=0.50
MIN_STAKE=0.35
MAX_STAKE=2.00
RISK_PERCENT=0.005
USE_MARTINGALE=false

# Connection
RECONNECT_BASE_DELAY=1000
RECONNECT_MAX_DELAY=30000
MAX_RECONNECT_ATTEMPTS=10
PING_INTERVAL=30000

# Data
DB_PATH=./data/boom_crash_ticks.db
LIVE_TRADES_DB_PATH=./data/live_trades.db
STORE_TICKS=true

# Production (Phase 7)
HEALTH_PORT=3456
LOG_DIR=./logs
REPORT_DIR=./reports/daily
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
